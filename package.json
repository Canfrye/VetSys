{
  "name": "vetsys",
  "private": true,
  "version": "1.0.0",
  "description": "Veteriner Klinik Yönetim Sistemi",
  "author": "VetSys Software",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "cross-env ELECTRON_DEV=true electron .",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on http://127.0.0.1:5173 && cross-env ELECTRON_DEV=true electron .\"",
    "electron:build": "cross-env ELECTRON=true vite build && cross-env ELECTRON_DEV=false electron .",
    "electron:pack": "cross-env ELECTRON=true vite build && electron-builder --dir --publish never",
    "electron:dist": "cross-env ELECTRON=true vite build && electron-builder --win nsis --publish never",
    "release": "cross-env ELECTRON=true vite build && electron-builder --win nsis --publish never"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@mui/x-data-grid": "^9.8.0",
    "@mui/x-date-pickers": "^9.10.0",
    "chart.js": "^4.5.1",
    "dayjs": "^1.11.21",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "react": "^19.2.7",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.7",
    "react-icons": "^5.7.0",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.0.12",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "vite": "^8.1.1",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.vetsys.app",
    "productName": "VetSys",
    "copyright": "Copyright © VetSys Software",
    "directories": {
      "output": "release",
      "buildResources": "electron/assets"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!**/node_modules/.cache/**",
          "!**/tests/**",
          "!**/*.test.js",
          "!**/.env"
        ]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/@prisma/**",
      "**/node_modules/.prisma/**"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/assets/icon.ico",
      "artifactName": "VetSys-Setup-${version}.${ext}",
      "executableName": "VetSys"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "VetSys",
      "installerIcon": "electron/assets/icon.ico",
      "uninstallerIcon": "electron/assets/icon.ico",
      "installerHeaderIcon": "electron/assets/icon.ico",
      "uninstallDisplayName": "VetSys",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "menuCategory": false,
      "displayLanguageSelector": false,
      "installerLanguages": [
        "tr_TR",
        "en_US"
      ],
      "language": "1055"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://updates.vetsys.local/releases/",
        "channel": "latest"
      }
    ]
  }
}
